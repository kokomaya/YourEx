{
  "name": "yourex",
  "displayName": "YourEx",
  "description": "Your little game of rEgular eXpression — Match the pattern. Understand the language.",
  "version": "0.0.1",
  "publisher": "kokomaya",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": [
    "onView:yourex-levels"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "yourex.startDecryption",
        "title": "Start Decryption",
        "category": "YourEx"
      },
      {
        "command": "yourex.openLevel",
        "title": "Open Level",
        "category": "YourEx"
      },
      {
        "command": "yourex.signalProgress",
        "title": "Signal Progress",
        "category": "YourEx"
      },
      {
        "command": "yourex.leaderboard",
        "title": "Leaderboard",
        "category": "YourEx"
      },
      {
        "command": "yourex.promptReplay",
        "title": "Prompt Replay",
        "category": "YourEx"
      },
      {
        "command": "yourex.switchMode",
        "title": "Switch Mode",
        "category": "YourEx"
      },
      {
        "command": "yourex.showCurrentMode",
        "title": "Show Current Mode",
        "category": "YourEx"
      }
    ],
    "configuration": {
      "title": "YourEx",
      "properties": {
        "yourex.mode.default": {
          "type": "string",
          "enum": ["user", "developer"],
          "default": "user",
          "description": "Default run mode used when no persisted mode exists yet."
        },
        "yourex.mode.allowDeveloper": {
          "type": "boolean",
          "default": true,
          "description": "Allow switching to Developer Mode that bypasses chapter/level locks."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "yourex-sidebar",
          "title": "YourEx — Signal Decryption",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "yourex-sidebar": [
        {
          "id": "yourex-levels",
          "name": "Signal Decryption",
          "type": "tree"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "yourex-levels",
        "contents": "📡 接入未知信号源…\n\n检测到异常信号标记：rEx\n\n[开始解密](command:yourex.startDecryption)\n\n或点击下方关卡列表直接进入。"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "npm run compile && npm run build:webview",
    "compile": "tsc -p ./tsconfig.json",
    "watch": "tsc -watch -p ./tsconfig.json",
    "pretest": "npm run compile",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:webview": "cd webview-ui && npm run build",
    "dev:webview": "cd webview-ui && npm run dev"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0"
  }
}
